VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Spotify — Client Credentials flow for track search
# WARNING: VITE_ vars are public in the client bundle.
# Move to a Supabase Edge Function proxy before going public.
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
